# ──────────────────────────────────────────────────────────────
# Copiez ce fichier en .env.local et remplissez les valeurs.
# Copy this file to .env.local and fill in the values.
# ──────────────────────────────────────────────────────────────

# Base de données SQLite (chemin local — ne pas modifier sauf besoin)
DATABASE_URL="file:./dev.db"

# Clé secrète NextAuth — générez-en une avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="changez-cette-valeur-par-une-cle-aleatoire"

# URL de l'application (http://localhost:3000 en développement)
NEXTAUTH_URL="http://localhost:3000"
