# ──────────────────────────────────────────────────────────────
# Copiez ce fichier en .env.local (développement) ou configurez
# ces variables directement dans le tableau de bord Vercel.
# Copy this file to .env.local (dev) or set in Vercel dashboard.
# ──────────────────────────────────────────────────────────────

# ── Supabase / PostgreSQL ────────────────────────────────────
#
# DATABASE_URL : URL de connexion avec pooler (Transaction mode)
#   → Supabase Dashboard > Project Settings > Database > Connection pooling
#   → Mode : Transaction  |  Port : 6543
#   Exemple : postgresql://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL : URL de connexion directe (utilisée par les migrations Prisma)
#   → Supabase Dashboard > Project Settings > Database > Connection string
#   → Mode : URI  |  Port : 5432
#   Exemple : postgresql://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres
#
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:[password]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ── NextAuth.js ──────────────────────────────────────────────
#
# NEXTAUTH_SECRET : clé secrète pour signer les JWT
#   Générez-en une avec :
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
NEXTAUTH_SECRET="changez-cette-valeur-par-une-cle-aleatoire"

# NEXTAUTH_URL : URL publique de votre application
#   En développement : http://localhost:3000
#   En production Vercel : https://votre-projet.vercel.app
#
NEXTAUTH_URL="http://localhost:3000"
